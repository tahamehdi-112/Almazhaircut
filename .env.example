# GEMINI_API_KEY: Required for Gemini AI API calls (if used).
# This value can be provided via your hosting platform's secrets or a local .env file.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this site is hosted.
# Set this to your deployment URL; used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
